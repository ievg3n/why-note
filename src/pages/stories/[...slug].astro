---
import { getCollection, render } from "astro:content"
import Layout from "@/layouts/Layout.astro"
import MobileTOC from "@/components/posts/MobileTOC.astro"
import DesktopTOC from "@/components/posts/DesktopTOC.astro"
import ShareButtons from "@/components/posts/ShareButtons.astro"
import { Image } from "astro:assets"
import { siteConfig } from "@/config"
import { parseDate } from "@/utils/date"
import { calcReadTime } from "@/utils/reading-time"

export async function getStaticPaths() {
    const allStories = await getCollection("story")
    const stories = allStories
        .filter((s) => !s.data.draft)
        .sort((a, b) => {
            return (
                parseDate(b.data.date).getTime() -
                parseDate(a.data.date).getTime()
            )
        })

    return stories.map((story, index) => ({
        params: { slug: story.id },
        props: {
            story,
            prevStory:
                index < stories.length - 1
                    ? {
                          id: stories[index + 1].id,
                          title: stories[index + 1].data.title
                      }
                    : null,
            nextStory:
                index > 0
                    ? {
                          id: stories[index - 1].id,
                          title: stories[index - 1].data.title
                      }
                    : null
        }
    }))
}

const { story, prevStory, nextStory } = Astro.props
const { Content, headings } = await render(story)

const readTime = calcReadTime(story.body ?? "")

const dateObj = parseDate(story.data.date)
const dateFormatted = dateObj.toLocaleDateString("en-US", {
    timeZone: "UTC",
    month: "short",
    day: "numeric",
    year: "numeric"
})
const isoDate = dateObj.toISOString()

const ogImage = story.data.image?.src
const storyUrl = new URL(Astro.url.pathname, Astro.site || Astro.url.origin)
    .href

const allEntries = await getCollection("story")
const relatedStories = allEntries
    .filter((s) => !s.data.draft && s.id !== story.id)
    .map((s) => ({
        id: s.id,
        title: s.data.title,
        frontmatter: s.data.frontmatter,
        readTime: calcReadTime(s.body ?? "")
    }))
    .slice(0, 3)
---

<Layout
    title={`${story.data.title} | ${siteConfig.title}`}
    description={story.data.frontmatter}
    type="article"
    image={ogImage}
>
    <div class="fixed top-0 left-0 w-full z-50 bg-transparent">
        <div
            id="progress-bar"
            class="h-0.75 bg-primary transition-all duration-150 ease-out"
            style="width: 0%"
        >
        </div>
    </div>
    <main class="page pb-20 mt-10 relative">
        <div class="mb-10 w-full">
            <a
                href="/stories"
                class="text-sm font-medium text-muted-foreground hover:text-primary transition-colors flex items-center gap-2"
            >
                <span>←</span> Back to stories
            </a>
        </div>

        <article class="w-full max-w-full">
            <header class="mb-14 lg:mb-20">
                <h1
                    class="text-4xl md:text-5xl lg:text-5xl font-bold tracking-tight mb-6 text-foreground leading-tight"
                >
                    {story.data.title}
                </h1>
                <div
                    class="flex items-center gap-2 text-sm text-muted-foreground mb-4 flex-wrap"
                >
                    <time datetime={isoDate}>{dateFormatted}</time>
                    <span>·</span>
                    <span>{readTime} min read</span>
                </div>
                <div class="mb-6">
                    <ShareButtons url={storyUrl} title={story.data.title} />
                </div>
                {
                    story.data.image && (
                        <Image
                            src={story.data.image}
                            alt={story.data.title}
                            class="w-full h-auto rounded-xl mt-8 object-cover aspect-video border border-border"
                            loading="eager"
                            fetchpriority="high"
                        />
                    )
                }
            </header>
        </article>

        <div class="flex flex-col lg:flex-row gap-10 relative">
            <div class="flex-1 w-full max-w-full">
                <div class="prose-blog">
                    <div class="drop-cap">
                        <Content />
                    </div>
                </div>
            </div>

            {headings.length > 0 && <DesktopTOC headings={headings} />}
        </div>

        <div class="mt-16 pt-8 border-t border-border">
            <span
                class="text-xs uppercase tracking-widest text-muted-foreground mb-4 block"
                >Share this story</span
            >
            <ShareButtons url={storyUrl} title={story.data.title} />
        </div>

        {
            relatedStories.length > 0 && (
                <div class="mt-16">
                    <span class="text-xs uppercase tracking-widest text-muted-foreground mb-6 block">
                        More stories
                    </span>
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                        {relatedStories.map((related) => (
                            <a
                                href={`/stories/${related.id}`}
                                class="group p-4 border border-border rounded-lg hover:bg-muted transition-colors"
                            >
                                <h3 class="font-medium group-hover:text-primary transition-colors line-clamp-2">
                                    {related.title}
                                </h3>
                                <p class="text-sm text-muted-foreground mt-2 line-clamp-2">
                                    {related.frontmatter}
                                </p>
                                <span class="text-xs text-muted-foreground mt-2 block">
                                    {related.readTime} min read
                                </span>
                            </a>
                        ))}
                    </div>
                </div>
            )
        }

        <nav class="mt-16 pt-8 border-t border-border grid grid-cols-2 gap-4">
            <div>
                {
                    prevStory && (
                        <a
                            href={`/stories/${prevStory.id}`}
                            class="group flex flex-col gap-1"
                        >
                            <span class="text-xs text-muted-foreground">
                                ← Older
                            </span>
                            <span class="text-sm font-medium group-hover:text-primary transition-colors line-clamp-1">
                                {prevStory.title}
                            </span>
                        </a>
                    )
                }
            </div>
            <div class="text-right">
                {
                    nextStory && (
                        <a
                            href={`/stories/${nextStory.id}`}
                            class="group flex flex-col gap-1 items-end"
                        >
                            <span class="text-xs text-muted-foreground">
                                Newer →
                            </span>
                            <span class="text-sm font-medium group-hover:text-primary transition-colors line-clamp-1">
                                {nextStory.title}
                            </span>
                        </a>
                    )
                }
            </div>
        </nav>

        <div class="mt-10 flex justify-center">
            <a
                href="/stories"
                class="text-sm font-medium text-muted-foreground hover:text-primary transition-colors flex items-center gap-2"
            >
                ← Back to stories
            </a>
        </div>
    </main>

    {headings.length > 0 && <MobileTOC headings={headings} />}
    <script
        is:inline
        type="application/ld+json"
        set:html={JSON.stringify({
            "@context": "https://schema.org",
            "@type": "BlogPosting",
            headline: story.data.title,
            image: ogImage
                ? new URL(ogImage, Astro.site || Astro.url.origin).href
                : undefined,
            author: {
                "@type": "Person",
                name: siteConfig.author.name
            },
            datePublished: isoDate,
            description: story.data.frontmatter,
            url: Astro.site
                ? new URL(Astro.url.pathname, Astro.site).href
                : Astro.url.href
        })}
    />

    <script>
        import "@/scripts/reading-progress.ts"
    </script>
</Layout>
