---
import { getCollection } from "astro:content"
import Layout from "@/layouts/Layout.astro"
import Stories from "@/components/Stories.astro"
import { siteConfig } from "@/config"

export async function getStaticPaths() {
    const entries = await getCollection("story")
    const published = entries.filter((entry) => !entry.data.draft)
    const totalPages = Math.ceil(published.length / siteConfig.postsPerPage)

    // page 1 is served by index.astro; emit pages 2..totalPages
    return Array.from({ length: totalPages - 1 }, (_, i) => i + 2).map(
        (page) => ({
            params: { page: String(page) }
        })
    )
}

const { page } = Astro.params
const pageNum = Number(page)
---

<Layout>
    <Stories page={pageNum} />
</Layout>
