---
import { getCollection } from "astro:content"
import { siteConfig } from "@/config"
import { calcReadTime } from "@/utils/reading-time"

interface Props {
    page?: number
}

const { page = 1 } = Astro.props

const entries = await getCollection("story")
const allStories = entries
    .filter((entry) => !entry.data.draft)
    .map((entry) => ({
        id: entry.id,
        slug: entry.id,
        readTime: calcReadTime(entry.body ?? ""),
        ...entry.data
    }))
    .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime())

const totalPages = Math.ceil(allStories.length / siteConfig.postsPerPage)
const stories = allStories.slice(
    (page - 1) * siteConfig.postsPerPage,
    page * siteConfig.postsPerPage
)

type MappedStory = (typeof stories)[number]

const monthName = (n: number) =>
    new Date(2000, n - 1).toLocaleString("en", { month: "short" })

const dateRange = (storiesInMonth: MappedStory[]) => {
    const days = storiesInMonth.map((s) => Number(s.date.split("/")[1]))
    const min = Math.min(...days)
    const max = Math.max(...days)
    return min === max ? String(min) : `${min} - ${max}`
}

const grouped = stories.reduce(
    (acc, story) => {
        const [m, , y] = story.date.split("/")
        const month = monthName(Number(m))
        if (!acc[y]) acc[y] = {}
        if (!acc[y][month]) acc[y][month] = []
        acc[y][month].push(story)
        return acc
    },
    {} as Record<string, Record<string, MappedStory[]>>
)

const pageUrl = (p: number) => (p === 1 ? "/stories" : `/stories/${p}`)
---

<main class="page">
    <span class="uppercase text-primary font-medium tracking-widest"
        >stories</span
    >

    <h1 class="text-4xl mt-10">Narratives</h1>
    <p class="text-lg max-w-122 text-muted-foreground">
        Longer-form stories and explorations that don't fit the typical blog
        post format.
    </p>

    <section class="mt-20 my-5">
        {
            Object.keys(grouped)
                .sort((a, b) => Number(b) - Number(a))
                .map((year) => (
                    <section>
                        <h2 class="text-2xl">{year}</h2>
                        {Object.entries(grouped[year]).map(
                            ([month, monthStories]) => (
                                <section>
                                    <h3 class="text-sm text-muted-foreground uppercase font-medium tracking-widest">
                                        {month} {dateRange(monthStories)}
                                    </h3>
                                    <hr class="mt-2" />
                                    <section class="flex flex-col gap-3 my-5">
                                        {monthStories.map((story) => (
                                            <section class="flex flex-col gap-2 group hover:bg-muted px-3 py-8 rounded-md transition-all duration-300 relative overflow-hidden">
                                                <div class="flex flex-col md:flex-row gap-2 md:justify-between md:items-start">
                                                    <a
                                                        href={`/stories/${story.slug}`}
                                                    >
                                                        <h2 class="text-2xl group-hover:text-primary leading-tight">
                                                            {story.title}
                                                        </h2>
                                                    </a>
                                                    <span class="text-muted-foreground text-xs shrink-0 whitespace-nowrap md:mt-1 md:text-right text-left mt-1">
                                                        {story.readTime} min
                                                        read
                                                    </span>
                                                </div>
                                                <p class="text-muted-foreground">
                                                    {story.frontmatter}
                                                </p>
                                            </section>
                                        ))}
                                    </section>
                                </section>
                            )
                        )}
                    </section>
                ))
        }
    </section>

    {
        totalPages > 1 && (
            <nav
                class="flex items-center justify-center gap-2 mt-16 mb-10"
                aria-label="Pagination"
            >
                {page > 1 && (
                    <a
                        href={pageUrl(page - 1)}
                        class="text-sm text-muted-foreground hover:text-primary transition-colors px-3 py-2"
                        aria-label="Previous page"
                    >
                        ←
                    </a>
                )}
                {Array.from({ length: totalPages }, (_, i) => i + 1).map(
                    (p) => (
                        <a
                            href={pageUrl(p)}
                            class={`text-sm px-3 py-2 rounded-md transition-colors ${
                                p === page
                                    ? "bg-primary text-primary-foreground font-medium"
                                    : "text-muted-foreground hover:text-primary hover:bg-muted"
                            }`}
                            aria-current={p === page ? "page" : undefined}
                        >
                            {p}
                        </a>
                    )
                )}
                {page < totalPages && (
                    <a
                        href={pageUrl(page + 1)}
                        class="text-sm text-muted-foreground hover:text-primary transition-colors px-3 py-2"
                        aria-label="Next page"
                    >
                        →
                    </a>
                )}
            </nav>
        )
    }
</main>
